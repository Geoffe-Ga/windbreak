# Forecast-engine import boundary (SPEC S8.3).
#
# Notes:
#   1. `hedgekit.connector.models` is deliberately allowed: it holds read-only
#      data models (NormalizedMarket) that pipeline.py imports only under
#      TYPE_CHECKING. This forbidden-modules contract bans `hedgekit.connector`
#      submodules individually rather than the whole package precisely so that
#      the models submodule stays reachable.
#   2. The PRIMARY, CI-enforced guarantee is the pure-stdlib `ast` check in
#      tests/forecast/test_sandbox.py, which is strictly STRONGER than this
#      config: it also forbids a bare `from hedgekit.connector import X`
#      (module-plus-symbol) import AND every relative import (`from ..ledger
#      import store`, `from . import config`) -- loopholes a forbidden-modules
#      contract cannot express -- while carving out the same
#      `hedgekit.connector.models` allowance.
#   3. Wiring import-linter (plans/architecture/run-check.sh) into CI is a
#      follow-up (chore(ci): wire import-linter into CI). Until then this file
#      documents the contract; the pytest AST check is the enforcing gate.

[importlinter]
root_package = hedgekit

[importlinter:contract:forecast-sandbox-boundary]
name = Forecast engine may not reach ledger/order/risk/config machinery (SPEC S8.3)
type = forbidden
source_modules =
    hedgekit.forecast
forbidden_modules =
    hedgekit.ledger
    hedgekit.order_gateway
    hedgekit.riskkernel
    hedgekit.config
    hedgekit.connector.interface
    hedgekit.connector.snapshot
    hedgekit.connector.fake
    hedgekit.connector.kalshi

# Signing-key isolation boundary (SPEC S5.3).
#
# Notes:
#   1. Only the `hedgekit.riskkernel` package may import the approval-token
#      signing key handle; every other shipped module is enumerated below as a
#      forbidden source. `hedgekit.riskkernel` itself is deliberately absent
#      from `source_modules`, so the package that owns the key may still reach
#      its own signing submodule.
#   2. As with the forecast boundary above, the PRIMARY, enforcing gate is the
#      pure-stdlib `ast` check in tests/riskkernel/test_process_isolation.py --
#      it is strictly STRONGER than this config (it also flags a bare
#      `from hedgekit.riskkernel import signing` module-plus-symbol import AND
#      every relative import, loopholes a forbidden-modules contract cannot
#      express). Wiring import-linter into CI is a follow-up; until then this
#      file documents the contract and the pytest AST check enforces it.

[importlinter:contract:signing-key-isolation]
name = Only the Risk Kernel may import the approval-token signing key handle (SPEC S5.3)
type = forbidden
source_modules =
    hedgekit.alerts
    hedgekit.config
    hedgekit.connector
    hedgekit.dashboard
    hedgekit.forecast
    hedgekit.ledger
    hedgekit.numeric
    hedgekit.order_gateway
    hedgekit.pipeline
    hedgekit.screener
    hedgekit.tokens
    hedgekit.main
    hedgekit.logging_setup
forbidden_modules =
    hedgekit.riskkernel.signing

# Order-submission-client isolation boundary (SPEC S5.2/S5.3).
#
# Notes:
#   1. Only the `hedgekit.order_gateway` package may import the exchange
#      order-submission client `hedgekit.connector.paper` (and thereby hold a
#      live trading credential); every other shipped module is enumerated below
#      as a forbidden source. Both `hedgekit.order_gateway` (the sole intended
#      consumer, issue #37's `PaperSubmitter`) and `hedgekit.connector` (where
#      `PaperExchange` itself is defined and already re-exported) are
#      deliberately absent from `source_modules`.
#   2. As with the boundaries above, the PRIMARY, enforcing gate is the
#      pure-stdlib `ast` check in tests/architecture/test_import_boundaries.py --
#      it is strictly STRONGER than this config (it also flags a bare
#      `from hedgekit.connector import paper` / `... import PaperExchange`
#      module-plus-symbol import AND every relative import, loopholes a
#      forbidden-modules contract cannot express). Wiring import-linter into CI
#      is a follow-up; until then this file documents the contract and the
#      pytest AST check enforces it.

[importlinter:contract:order-submission-client-isolation]
name = Only the Order Gateway may import the exchange order-submission client (SPEC S5.2/S5.3)
type = forbidden
source_modules =
    hedgekit.alerts
    hedgekit.config
    hedgekit.dashboard
    hedgekit.forecast
    hedgekit.ledger
    hedgekit.numeric
    hedgekit.pipeline
    hedgekit.riskkernel
    hedgekit.screener
    hedgekit.tokens
    hedgekit.main
    hedgekit.logging_setup
forbidden_modules =
    hedgekit.connector.paper
