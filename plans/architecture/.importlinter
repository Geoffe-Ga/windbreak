# Forecast-engine import boundary (SPEC S8.3).
#
# Notes:
#   1. `windbreak.connector.models` is deliberately allowed: it holds read-only
#      data models (NormalizedMarket) that pipeline.py imports only under
#      TYPE_CHECKING. This forbidden-modules contract bans `windbreak.connector`
#      submodules individually rather than the whole package precisely so that
#      the models submodule stays reachable.
#   2. The PRIMARY, CI-enforced guarantee is the pure-stdlib `ast` check in
#      tests/forecast/test_sandbox.py, which is strictly STRONGER than this
#      config: it also forbids a bare `from windbreak.connector import X`
#      (module-plus-symbol) import AND every relative import (`from ..ledger
#      import store`, `from . import config`) -- loopholes a forbidden-modules
#      contract cannot express -- while carving out the same
#      `windbreak.connector.models` allowance.
#   3. import-linter (plans/architecture/run-check.sh) is now a CI-enforced
#      gate, wired in via scripts/check-all.sh (issue #91). The pure-stdlib
#      AST check remains the strictly-stronger PRIMARY layer; this contract is
#      independent defense-in-depth.

[importlinter]
root_package = windbreak

[importlinter:contract:forecast-sandbox-boundary]
name = Forecast engine may not reach ledger/order/risk/config machinery (SPEC S8.3)
type = forbidden
allow_indirect_imports = True
source_modules =
    windbreak.forecast
forbidden_modules =
    windbreak.ledger
    windbreak.order_gateway
    windbreak.riskkernel
    windbreak.config
    windbreak.connector.interface
    windbreak.connector.snapshot
    windbreak.connector.fake
    windbreak.connector.kalshi

# Signing-key isolation boundary (SPEC S5.3).
#
# Notes:
#   1. Only the `windbreak.riskkernel` package may import the approval-token
#      signing key handle; every other shipped module is enumerated below as a
#      forbidden source. `windbreak.riskkernel` itself is deliberately absent
#      from `source_modules`, so the package that owns the key may still reach
#      its own signing submodule.
#   2. As with the forecast boundary above, the PRIMARY, enforcing gate is the
#      pure-stdlib `ast` check in tests/riskkernel/test_process_isolation.py --
#      it is strictly STRONGER than this config (it also flags a bare
#      `from windbreak.riskkernel import signing` module-plus-symbol import AND
#      every relative import, loopholes a forbidden-modules contract cannot
#      express). import-linter is now a CI-enforced gate too, wired in via
#      scripts/check-all.sh (issue #91); this contract is independent
#      defense-in-depth behind that stronger AST check.

[importlinter:contract:signing-key-isolation]
name = Only the Risk Kernel may import the approval-token signing key handle (SPEC S5.3)
type = forbidden
allow_indirect_imports = True
source_modules =
    windbreak.alerts
    windbreak.config
    windbreak.connector
    windbreak.dashboard
    windbreak.drills
    windbreak.evaluation
    windbreak.forecast
    windbreak.ledger
    windbreak.net
    windbreak.numeric
    windbreak.order_gateway
    windbreak.pipeline
    windbreak.preflight
    windbreak.reports
    windbreak.scheduler
    windbreak.screener
    windbreak.selector
    windbreak.tokens
    windbreak.__main__
    windbreak.main
    windbreak.logging_setup
forbidden_modules =
    windbreak.riskkernel.signing

# Order-submission-client isolation boundary (SPEC S5.2/S5.3).
#
# Notes:
#   1. Only the `windbreak.order_gateway` package -- and, since issue #48, the
#      `windbreak.scheduler` PAPER-mode composition root -- may import the
#      exchange order-submission client `windbreak.connector.paper`; every other
#      shipped module is enumerated below as a forbidden source.
#      `windbreak.order_gateway` (the sole intended trading consumer, issue #37's
#      `PaperSubmitter`), `windbreak.connector` (where `PaperExchange` itself is
#      defined and already re-exported), and `windbreak.scheduler` (which
#      constructs a `PaperExchange` ONLY inside its `build_paper_deps` PAPER
#      factory -- the boundary's intent, keeping the paper fake out of the
#      RESEARCH/LIVE trading path, is preserved because the RESEARCH loop never
#      imports `windbreak.scheduler` at all) are deliberately absent from
#      `source_modules`.
#   2. As with the boundaries above, the PRIMARY, enforcing gate is the
#      pure-stdlib `ast` check in tests/architecture/test_import_boundaries.py --
#      it is strictly STRONGER than this config (it also flags a bare
#      `from windbreak.connector import paper` / `... import PaperExchange`
#      module-plus-symbol import AND every relative import, loopholes a
#      forbidden-modules contract cannot express). import-linter is now a
#      CI-enforced gate too, wired in via scripts/check-all.sh (issue #91);
#      this contract is independent defense-in-depth behind that stronger AST
#      check.

[importlinter:contract:order-submission-client-isolation]
name = Only the Order Gateway may import the exchange order-submission client (SPEC S5.2/S5.3)
type = forbidden
allow_indirect_imports = True
source_modules =
    windbreak.alerts
    windbreak.config
    windbreak.dashboard
    windbreak.drills
    windbreak.evaluation
    windbreak.forecast
    windbreak.ledger
    windbreak.net
    windbreak.numeric
    windbreak.pipeline
    windbreak.preflight
    windbreak.reports
    windbreak.riskkernel
    windbreak.screener
    windbreak.selector
    windbreak.tokens
    windbreak.__main__
    windbreak.main
    windbreak.logging_setup
forbidden_modules =
    windbreak.connector.paper
